{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://base44.app/api/:path*"
    },
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|llms\\.txt|google.*\\.html|favicon.*|manifest\\.json|.*\\.png|.*\\.svg|.*\\.webp|.*\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
